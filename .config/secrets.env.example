# Pantera - Copy this file to secrets.env and fill in your values
# cp .config/secrets.env.example .config/secrets.env

# Required: Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Chat ID for reminder nudges and morning briefings (get from @userinfobot)
# TELEGRAM_CHAT_ID=123456789

# Production (Railway): Use webhooks to avoid "Conflict: only one bot instance" errors.
# Set this to your public URL, or leave unset - we auto-detect RAILWAY_PUBLIC_DOMAIN.
# WEBHOOK_URL=https://your-app.up.railway.app

# Database (Postgres with pgvector)
# Option A: Full URL (ensure it includes host:port)
DATABASE_PUBLIC_URL=postgresql://user:password@host.railway.app:12345/railway
# Option B: Railway components (if DATABASE_PUBLIC_URL has empty host/port)
# PGHOST=xxx.railway.app
# PGPORT=12345
# PGUSER=postgres
# PGPASSWORD=xxx
# PGDATABASE=railway

# AI APIs
# OpenAI: for Whisper (voice), embeddings, and fallback classification
OPENAI_API_KEY=your_openai_api_key

# Anthropic: for classification (optional, falls back to OpenAI if not set)
ANTHROPIC_API_KEY=your_anthropic_api_key

# GitHub: for git push (optional, use make push or scripts/push.sh)
# Create at: GitHub → Settings → Developer settings → Personal access tokens
# Required scope: repo
GITHUB_PAT_PANTERA_CLAWW_APP=your_github_pat
